{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Delve into Docker",
      "type": "go",
      "request": "attach",
      "mode": "remote",
      "substitutePath": [
        {
          "from": "${workspaceFolder}/",
          "to": "/app/",
        },
      ],
      "port": 2345,
      "host": "127.0.0.1",
      // "showLog": true,
      "apiVersion": 2,
      "trace": "verbose",
      "dlvLoadConfig": {
        "followPointers": true,
        "maxVariableRecurse": 3,
        "maxStringLen": 400,
        "maxArrayValues": 400,
        "maxStructFields": -1
      },
      "preLaunchTask": "attach-delve",
      "postDebugTask": "dettach-delve",
    }
  ]
}
